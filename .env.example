# nonebot-plugin-kancolle 配置示例
# ============================================================
# 复制需要的项到 nonebot 项目的 .env 文件并按需修改。
# 所有项都有默认值，不配置也能跑。
# 配置项前缀统一为 KANCOLLE_（nonebot 的 pydantic 约定）。
# 行首 # 表示注释；去掉 # 即可启用。

# === 数据源 ===

# 启用的数据源列表，按字段融合优先级排序
# 可选值：kcanotify（stats/改造链主源）、kc3（中英文名翻译）
# 默认两个都启用
# KANCOLLE_DATA_SOURCES=["kcanotify","kc3"]

# 自动检查数据更新的间隔（小时）
# 默认 24（每天一次）；设为 0 禁用自动更新，仅手动触发
# KANCOLLE_DATA_UPDATE_INTERVAL_HOURS=24

# 插件启动时是否自动检查一次更新
# 默认 false（避免启动慢）；true 时启动后 30 秒触发一次
# KANCOLLE_DATA_UPDATE_ON_STARTUP=false

# GitHub API token，避免匿名限流（匿名 60/hr，带 token 5000/hr）
# 仅在拉取 kc3-translations 仓库的 commit_sha 时使用
# 不配置也能用（每周更新一次远低于 60/hr 限额）
# KANCOLLE_DATA_GITHUB_TOKEN=


# === 渲染 ===

# 图片渲染主题：dark / light
# dark = 深色背景 + 浅色字；light = 白底深色字
# KANCOLLE_RENDER_THEME=dark

# 立绘缓存保留天数（kcanotify 立绘通过 kcwiki.cn 拉取，本地缓存）
# 默认 30 天；过期后下次查询会重新拉取
# 注：渲染输出（基础卡/详情/改造链图）的缓存不靠 TTL，而是靠 data_version
#     自动失效（数据更新时整批清空），所以这里只影响立绘
# KANCOLLE_RENDER_CACHE_TTL_DAYS=30

# 渲染视窗宽度（像素）
# 默认 800，QQ/微信内显示效果良好
# 范围 400-1600；改小可加快渲染但内容拥挤
# KANCOLLE_RENDER_VIEWPORT_WIDTH=800


# === 查询 ===

# 多命中时列表展示的最大条数
# 超过则只展示名字；默认 5
# KANCOLLE_QUERY_MAX_LIST_ITEMS=5

# rapidfuzz 兜底匹配的最低分数（0-100）
# 低于此分数的候选不视为命中；默认 60
# 调高 = 更严格（少误匹配，可能漏召回）；调低 = 更宽松
# KANCOLLE_QUERY_MIN_FUZZY_SCORE=60


# === 使用提示 ===
#
# 1. SUPERUSER 权限：在 nonebot 主 .env 里设置 SUPERUSERS=["你的QQ号"]
#    才能触发「更新舰娘数据」指令
#
# 2. 数据目录：插件数据存在 nonebot_plugin_localstore 分配的目录
#    （通常是 nonebot 项目下的 data/nonebot_plugin_kancolle/）
#    包含：
#      master.db              - 主数据库
#      cache/render/          - 渲染图缓存
#      cache/art/ship/        - 立绘缓存
#
# 3. 首次启动：插件包内含 seed/master.db.gz 兜底数据（1681 艘舰）
#    数据目录为空时自动解压；立即就能查询，无需等更新
#
# 4. Playwright 浏览器：第一次渲染会自动下载 Chromium (~113MB)
#    缓存到 AppData/nonebot2/nonebot_plugin_htmlrender/，之后不再下载
